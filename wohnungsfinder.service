[Unit]
Description=Berlin Wohnungsfinder Scraper
After=network-online.target
Wants=network-online.target
# Group with the API under wohnungsfinder.target so stop/restart of the target
# propagates here. Independent otherwise (a target restart, not a hard bind).
PartOf=wohnungsfinder.target

[Service]
# ── Change these two lines to match your setup ────────────────────────────────
User=youruser
WorkingDirectory=/home/youruser/wohnungsfinder
# ─────────────────────────────────────────────────────────────────────────────

ExecStart=/usr/bin/python3 main.py
Restart=on-failure
RestartSec=30

# Capture stdout/stderr in journald (use: journalctl -u wohnungsfinder -f)
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
