{
  "telegram": {
    "bot_token": "***REMOVED***",
    "chat_ids": [
      "***REMOVED***",
      "***REMOVED***"
    ]
  },

  "hard_filters": {
    "max_rent": 1100,
    "min_rooms": 1,
    "max_rooms": 5,
    "block_if_wbs_required": false,
    "block_wbs_categories": ["WBS 100", "WBS 140", "WBS 160"],
    "block_keywords": [
        "Wohnen ab 55", "Wohnen ab 60", "Wohnen ab 65",
        "Seniorenwohnung", "nur für Senioren",
        "Studentenwohnung", "Studenten", "Studentenwerk",
        "WBS 100", "WBS 140", "WBS 160"
    ]
},

"priority_scoring": {
    "rules": [
        { "name": "No WBS",                  "field": "wbs",        "match": "nicht erforderlich", "points": 30 },
        { "name": "Total Rent under €700",    "field": "total_rent",  "max": 700,                    "points": 30 },
        { "name": "Total Rent €700–€900",     "field": "total_rent",  "min": 700,  "max": 900,       "points": 20 },
        { "name": "Total Rent €900–€1100",    "field": "total_rent",  "min": 900,  "max": 1100,      "points": 10 },
        { "name": "Large: 2+ rooms",    "field": "rooms",      "min": 3,                       "points": 15 },
        { "name": "Good: 2 rooms",      "field": "rooms",      "min": 2,    "max": 3,          "points": 10 },
        { "name": "Ok: 1 rooms",        "field": "rooms",      "min": 1,    "max": 2,          "points": 5 },
        { "name": "Large: 70m²+",       "field": "size_m2",    "min": 70,                      "points": 15 },
        { "name": "Medium: 50–70m²",    "field": "size_m2",    "min": 50,   "max": 70,         "points": 10  },
        { "name": "Small: 30–50m²",    "field": "size_m2",    "min": 30,   "max": 50,         "points": 5  },
        { "name": "Has balcony",        "field": "features",   "contains": "Balkon",           "points": 5 },
        { "name": "Has elevator",       "field": "features",   "contains": "Aufzug",           "points": 2  },
        { "name": "Has garden",         "field": "features",   "contains": "Garten",           "points": 1 },
        { "name": "Has fitted kitchen", "field": "features",   "contains": "Einbauküche",      "points": 10  },
        { "name": "Has cellar",         "field": "features",   "contains": "Keller",           "points": 1  },
        { "name": "Accessible",         "field": "features",   "contains": "Barrierefrei",     "points": 1  }
    ],
    "thresholds": {
        "high":   60,
        "medium": 25
    }
},
  "scraper": {
    "url": "https://www.inberlinwohnen.de/wohnungsfinder",
    "interval_minutes": 12,
    "jitter_minutes":    3,
    "request_timeout":  30,
    "store_file": "data/listings.db",
    "log_file":   "logs/scraper.log",
    "log_level":  "INFO"
  }
}
